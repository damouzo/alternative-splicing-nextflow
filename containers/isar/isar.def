# Apptainer / Singularity definition for IsoformSwitchAnalyzeR
# Build: apptainer build /data/BCI-KRP/containers/isar-1.0.0.sif containers/isar/isar.def
# Then pass --isar_container /path/to/isar-1.0.0.sif to the pipeline

Bootstrap: docker
From: bioconductor/bioconductor_docker:RELEASE_3_20

%labels
    org.opencontainers.image.description "IsoformSwitchAnalyzeR for isoform switch detection and functional annotation"
    org.opencontainers.image.source      "https://github.com/BCI-KRP/alternative-splicing-nextflow"

%post
    # Bioconductor packages: core ISAR stack
    R -e " \
        BiocManager::install(c( \
            'IsoformSwitchAnalyzeR', \
            'satuRn', \
            'DEXSeq', \
            'tximeta', \
            'tximport', \
            'BiocParallel' \
        ), update=FALSE, ask=FALSE) \
    "

    # CRAN packages used in R scripts and reports
    R -e " \
        install.packages(c( \
            'dplyr', 'tidyr', 'ggplot2', 'DT', \
            'rmarkdown', 'knitr', 'plotly', 'UpSetR' \
        ), repos='https://cloud.r-project.org', Ncpus=4) \
    "

    # pfamAnalyzeR — required for PFAM domain analysis
    R -e "BiocManager::install('remotes', update=FALSE, ask=FALSE)"
    R -e "remotes::install_github('kvittingseerup/pfamAnalyzeR', upgrade='never')"

    # Verify core packages load
    R -e "library(IsoformSwitchAnalyzeR); library(satuRn); library(tximeta); sessionInfo()"

%runscript
    exec "$@"
