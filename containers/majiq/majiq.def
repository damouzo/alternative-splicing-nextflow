# Apptainer / Singularity definition for MAJIQ V3
# Build: apptainer build majiq.sif majiq.def
# Then pass --majiq_sif /path/to/majiq.sif to the pipeline

Bootstrap: docker
From: python:3.12-slim

%labels
    org.opencontainers.image.description "MAJIQ V3 for Local Splicing Variation analysis"
    org.opencontainers.image.source      "https://github.com/BCI-KRP/alternative-splicing-nextflow"

%post
    apt-get update && apt-get install -y --no-install-recommends \
        gcc \
        g++ \
        make \
        libhts-dev \
        zlib1g-dev \
        git \
    && rm -rf /var/lib/apt/lists/*

    # Limit parallel C++ compilation to avoid OOM
    export CMAKE_BUILD_PARALLEL_LEVEL=2
    export MAX_JOBS=2

    pip install --no-cache-dir git+https://bitbucket.org/biociphers/majiq_academic.git

%environment
    export PATH="/usr/local/bin:$PATH"
    # MAJIQ_LICENSE_FILE must be set in the host environment or via --env
    # export MAJIQ_LICENSE_FILE=/path/to/majiq_license*.key

%runscript
    exec "$@"
