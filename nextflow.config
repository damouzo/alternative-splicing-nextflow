/*
 * -------------------------------------------------
 *  alternative-splicing-nextflow Nextflow config
 * -------------------------------------------------
 */

manifest {
    name            = 'alternative-splicing-nextflow'
    author          = 'BCI-KRP'
    homePage        = 'https://github.com/damouzo/alternative-splicing-nextflow'
    description     = 'Multi-tool differential alternative splicing analysis pipeline'
    mainScript      = 'main.nf'
    nextflowVersion = '!>=23.10.0'
    version         = '1.1.0'
}

// Global default params
params {
    // Input/output
    input        = null
    comparisons  = null
    outdir       = './results'
    
    // Reference files (must match what was used in the upstream nf-core/rnaseq run)
    gtf              = null
    genome_fasta     = null   // required when use_gffread = true
    transcript_fasta = null   // optional when use_gffread = true
    use_gffread      = false  // derive transcript FASTA from genome_fasta + gtf via gffread
    genome_build     = 'hg38' // for MAJIQ config
    
    // Library properties (from the nf-core/rnaseq run)
    strandedness = null     // 'unstranded', 'forward', or 'reverse'
    read_length  = null     // read length after trimming
    is_gencode   = false
    
    // Tool switches
    run_rmats     = true
    run_majiq     = true
    run_isar      = true
    run_leafcutter = false
    
    // rMATS defaults
    rmats_cstat               = 0.0001
    rmats_min_intron_length   = 50
    rmats_max_exon_length     = 500
    rmats_tstat_threads       = 6
    rmats_read_type           = 'paired'  // 'paired' or 'single'
    rmats_novel_ss            = false     // enable novel splice site detection (default: off)
    
    // MAJIQ (licence file required — obtain from majiq.biociphers.org)
    majiq_license             = System.getenv('MAJIQ_LICENSE_FILE') ?: null  // path to majiq_license*.key file
    majiq_sif                 = System.getenv('MAJIQ_SIF') ?: null            // path to majiq Apptainer .sif OR Docker image tag

    // Container overrides — default to GHCR images built and published by build-containers.yml.
    // Override via env var or --isar_container / --report_container / --pegasas_container flags.
    isar_container            = System.getenv('ISAR_CONTAINER')    ?: null   // default: ghcr.io/damouzo/alternative-splicing-nextflow/isar:latest
    report_container          = System.getenv('REPORT_CONTAINER')  ?: null   // default: ghcr.io/damouzo/alternative-splicing-nextflow/report:latest
    pegasas_container         = System.getenv('PEGASAS_CONTAINER') ?: null   // default: ghcr.io/damouzo/alternative-splicing-nextflow/pegasas:latest
    leafcutter_container      = System.getenv('LEAFCUTTER_CONTAINER') ?: null  // default: ghcr.io/damouzo/alternative-splicing-nextflow/leafcutter:latest
    majiq_min_denovo_reads    = 2
    majiq_min_intronic_cov    = 3
    majiq_min_reads           = 10
    majiq_min_nonzero         = 3
    majiq_delta_psi_threshold = 0.2
    majiq_probability_threshold = 0.95
    
    // ISAR defaults
    isar_alpha            = 0.05
    isar_dif_cutoff       = 0.1
    isar_gene_expr_cutoff = 1
    isar_iso_expr_cutoff  = 1     // min TPM per isoform; 0 retains unexpressed isoforms

    // ISAR full functional annotation — Tier A (PFAM + IUPred3)
    // Gate with --run_isar_full_annotation true; also provide --pfam_hmm
    run_isar_full_annotation = false        // enable PFAM + IUPred3 annotation steps
    pfam_hmm                 = null         // path to user-provided Pfam-A.hmm database
    
    // Report defaults
    report_fdr_cutoff  = 0.05
    report_dpsi_cutoff = 0.1

    // QC integration — point to the multiqc/star_salmon/ directory from nf-core/rnaseq
    // Enables the QC Metrics section in the HTML report (alignment, duplication, junction stats)
    nfcore_multiqc_dir = null

    // Organism for GO/KEGG enrichment (clusterProfiler); supported: 'human', 'mouse'
    organism = 'human'

    // Sashimi plots (rmats2sashimiplot) — optional, disabled by default
    run_sashimi          = false
    sashimi_top_n        = 10     // events per event type to plot
    sashimi_group1_label = 'group1'
    sashimi_group2_label = 'group2'
    sashimi_exon_scale   = 1
    sashimi_intron_scale = 5

    // PEGASAS: pathway activity × splicing PSI correlation — optional
    run_pegasas           = false
    pathway_gmt           = null   // GMT-format gene signature file (PEGASAS '>' separator or MSigDB TSV)
    salmon_merged_tpm     = null   // salmon.merged.gene_tpm.tsv from nf-core/rnaseq (genes × samples)
    pegasas_groups        = null   // TSV file: sample_id<TAB>group (one row per sample, same order as BAM list)
    pegasas_num_interval  = 40     // parallel KS enrichment processes per batch

    // DE + AS integration — optional
    de_results = null   // TSV with columns: gene_id, log2FC, padj (DESeq2/edgeR/limma output)

    // Boilerplate options
    help              = false
    publish_dir_mode  = 'copy'
    validate_params   = true
}

// Load base config
includeConfig 'conf/base.config'

// Load modules config
includeConfig 'conf/modules.config'

// Profiles
profiles {
    docker {
        docker.enabled         = true
        docker.runOptions      = '-u $(id -u):$(id -g)'
        singularity.enabled    = false
        // Limit local executor to avoid OOM on workstations / shared nodes
        executor {
            name      = 'local'
            cpus      = 16
            memory    = '48 GB'
            queueSize = 4
        }
    }
    
    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        docker.enabled         = false
        executor {
            name      = 'local'
            cpus      = 16
            memory    = '48 GB'
            queueSize = 4
        }
    }
    
    apptainer {
        apptainer.enabled      = true
        apptainer.autoMounts   = true
        docker.enabled         = false
        executor {
            name      = 'local'
            cpus      = 16
            memory    = '48 GB'
            queueSize = 4
        }
    }

    slurm {
        process.executor       = 'slurm'
        process.queue          = 'compute'
        process.clusterOptions = '--export=ALL'
        executor.queueSize     = 20
        executor.submitRateLimit = '10/1min'
    }

    test {
        includeConfig 'conf/test.config'
    }
    
    test_full {
        includeConfig 'conf/test_full.config'
    }

    // Force ISAR processes to run sequentially and cap resources for small
    // workstations. Use when the default uncapped parallelisation causes OOM
    // (satuRn is memory-bound — 32GB+ per concurrent ISAR_* task).
    // Activate with: -profile test,lowmem
    lowmem {
        process {
            withName: 'ISAR_IMPORT|ISAR_SWITCH_TEST|ISAR_EXTRACT_ORF|ISAR_SWITCH_CONSEQUENCES' {
                maxForks = 1
            }
        }
        executor {
            cpus      = 4
            memory    = '16 GB'
            queueSize = 2
        }
    }
}

// Capture exit codes from upstream processes when piping
process.shell = ['/bin/bash', '-euo', 'pipefail']
