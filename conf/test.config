/*
 * -------------------------------------------------
 *  Test config - minimal dataset for CI/CD
 * -------------------------------------------------
 */

params {
    config_profile_name        = 'Test profile'
    config_profile_description = 'Minimal test dataset to check pipeline function'

    // Limit resources
    max_cpus   = 2
    max_memory = '6.GB'
    max_time   = '6.h'

    // Input files (to be created)
    input       = 'https://raw.githubusercontent.com/BCI-KRP/alternative-splicing-nextflow/main/assets/samplesheet_test.csv'
    comparisons = 'https://raw.githubusercontent.com/BCI-KRP/alternative-splicing-nextflow/main/assets/comparisons_test.csv'
    
    // Reference files (minimal test references)
    // TODO: Add test data URLs when available
    gtf         = null
    strandedness = 'reverse'
    read_length  = 100
}
