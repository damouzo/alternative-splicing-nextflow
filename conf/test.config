/*
 * -------------------------------------------------
 *  Test profile — synthetic SE event dataset
 * -------------------------------------------------
 *  Run generate_demo_data.py first to populate test/:
 *
 *    python bin/generate_demo_data.py --outdir test
 *
 *  Then launch with:
 *
 *    nextflow run main.nf -profile docker,test
 *    nextflow run main.nf -profile apptainer,test
 *
 *  MAJIQ is disabled: it requires an academic licence
 *  and a user-built container (see containers/majiq/).
 *  To test MAJIQ locally, override:
 *    --run_majiq true --majiq_sif <path> --majiq_license <path>
 * -------------------------------------------------
 */

params {
    config_profile_name        = 'Test profile'
    config_profile_description = 'Synthetic SE event: ctrl vs treat, 3 replicates each. PSI 0.80 → 0.20.'

    // Resource caps — keep footprint small for CI / workstation use
    max_cpus   = 4
    max_memory = '8.GB'
    max_time   = '2.h'

    // Input — generated by bin/generate_demo_data.py
    input       = "${projectDir}/test/samplesheet.csv"
    comparisons = "${projectDir}/test/comparisons.csv"

    // Reference — minimal 2 kb single-chromosome FASTA + two-transcript GTF
    gtf          = "${projectDir}/test/ref/test.gtf"
    genome_fasta = "${projectDir}/test/ref/test.genome.fa"
    use_gffread  = true    // extract transcript FASTA from genome + GTF (no pre-built FASTA needed)

    // Library
    strandedness = 'unstranded'
    read_length  = 100

    // Tool switches — MAJIQ off (licence required); LeafCutter + ISAR full annotation off for speed
    run_rmats                = true
    run_majiq                = false
    run_isar                 = true
    run_leafcutter           = false
    run_isar_full_annotation = false

    // Output
    outdir = "${projectDir}/test/results"

    // Relax rMATS thresholds for minimal read counts
    rmats_cstat = 0.001     // default 0.0001; relax for low-coverage test data

    // Relax ISAR filters for single-gene test transcriptome
    isar_gene_expr_cutoff = 0   // gene TPM filter off — single-gene transcriptome is 100% TPM
    isar_iso_expr_cutoff  = 1   // keep default
}
