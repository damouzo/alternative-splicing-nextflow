/*
 * -------------------------------------------------
 *  Per-process resource overrides
 * -------------------------------------------------
 */

process {
    // Input validation
    withName: 'VALIDATE_INPUT' {
        cpus   = 1
        memory = 4.GB
        time   = 1.h
    }

    // ISAR process parallelisation is memory-bound. Default is uncapped —
    // the executor and per-process memory caps control concurrency.
    // Use the `lowmem` profile to force single-fork execution on small
    // workstations.

    withName: 'MAJIQ_PREPARE_ANNOTATION|MAJIQ_BUILD|MAJIQ_DELTAPSI' {
        maxForks = 1
    }

    withName: 'RMATS_PREP' {
        cpus     = 4
        memory   = 16.GB
        time     = 4.h
        maxForks = 2  // limit concurrent Apptainer mounts to avoid squashfuse fork exhaustion
    }
    
    withName: 'RMATS_POST' {
        cpus   = 8
        memory = { 32.GB * task.attempt }
        time   = { 8.h  * task.attempt }
    }

    // MAJIQ processes — requires a user-built image (academic licence, not public).
    // Build: docker build -t your-registry/majiq:3.0 containers/majiq/
    //         OR: apptainer build containers/majiq/majiq.sif containers/majiq/majiq.def
    // Then set params.majiq_sif to the image path/tag.
    withName: 'MAJIQ_BUILD|MAJIQ_DELTAPSI|MAJIQ_ORGANIZE_RESULTS' {
        container = { params.majiq_sif ?: error('MAJIQ container not configured. Build containers/majiq/Dockerfile and pass --majiq_sif <image>. See containers/majiq/Dockerfile for instructions.') }
    }

    withName: 'MAJIQ_BUILD' {
        cpus   = 8
        memory = 32.GB
        time   = 6.h
    }

    withName: 'MAJIQ_DELTAPSI' {
        cpus   = 8
        memory = 16.GB
        time   = 4.h
    }

    withName: 'MAJIQ_ORGANIZE_RESULTS' {
        cpus   = 2
        memory = 8.GB
        time   = 2.h
    }

    // IsoformSwitchAnalyzeR processes — use self-hosted image built from containers/isar/Dockerfile
    withName: 'GFFREAD_TRANSCRIPTOME' {
        cpus   = 2
        memory = 8.GB
        time   = 2.h
    }
    
    withName: 'ISAR_.*' {
        cpus      = 4
        memory    = 32.GB
        time      = 4.h
        container = { params.isar_container ?: 'ghcr.io/damouzo/alternative-splicing-nextflow/isar:latest' }
    }

    // Sashimi plots — uses the official xinglab rmats2sashimiplot image
    withName: 'SASHIMI_PLOTS' {
        cpus   = 4
        memory = { 16.GB * task.attempt }
        time   = { 4.h  * task.attempt }
    }

    // PEGASAS — Python 3 port, published to GHCR from containers/pegasas/Dockerfile
    withName: 'PEGASAS_PREPARE' {
        cpus      = 1
        memory    = 4.GB
        time      = 1.h
        container = { params.pegasas_container ?: 'ghcr.io/damouzo/alternative-splicing-nextflow/pegasas:latest' }
    }

    withName: 'PEGASAS_PATHWAY' {
        cpus      = { params.pegasas_num_interval as int }
        memory    = { 16.GB * task.attempt }
        time      = { 6.h  * task.attempt }
        container = { params.pegasas_container ?: 'ghcr.io/damouzo/alternative-splicing-nextflow/pegasas:latest' }
    }

    withName: 'PEGASAS_CORRELATION' {
        cpus      = 4
        memory    = { 16.GB * task.attempt }
        time      = { 4.h  * task.attempt }
        container = { params.pegasas_container ?: 'ghcr.io/damouzo/alternative-splicing-nextflow/pegasas:latest' }
    }

    // Report processes
    withName: 'RENDER_REPORT' {
        cpus      = 2
        memory    = 16.GB
        time      = 2.h
        container = { params.report_container ?: 'ghcr.io/damouzo/alternative-splicing-nextflow/report:latest' }
    }

    // ISAR full annotation — HMMER (PFAM) and IUPred3
    // Same isar container that has hmmer + iupred3 installed
    withName: 'ISAR_RUN_PFAM' {
        cpus      = { task.cpus }
        memory    = { 32.GB * task.attempt }
        time      = { 4.h  * task.attempt }
        container = { params.isar_container ?: 'ghcr.io/damouzo/alternative-splicing-nextflow/isar:latest' }
    }

    withName: 'ISAR_RUN_IUPRED' {
        cpus      = 4
        memory    = { 16.GB * task.attempt }
        time      = { 4.h  * task.attempt }
        container = { params.isar_container ?: 'ghcr.io/damouzo/alternative-splicing-nextflow/isar:latest' }
    }

    // LeafCutter
    withName: 'LEAFCUTTER_BAM2JUNC' {
        cpus      = 2
        memory    = 8.GB
        time      = 2.h
        container = { params.leafcutter_container ?: 'ghcr.io/damouzo/alternative-splicing-nextflow/leafcutter:latest' }
    }

    withName: 'LEAFCUTTER_CLUSTER' {
        cpus      = 4
        memory    = { 16.GB * task.attempt }
        time      = { 4.h  * task.attempt }
        container = { params.leafcutter_container ?: 'ghcr.io/damouzo/alternative-splicing-nextflow/leafcutter:latest' }
    }

    withName: 'LEAFCUTTER_DS' {
        cpus      = 8
        memory    = { 32.GB * task.attempt }
        time      = { 8.h  * task.attempt }
        container = { params.leafcutter_container ?: 'ghcr.io/damouzo/alternative-splicing-nextflow/leafcutter:latest' }
    }
}
