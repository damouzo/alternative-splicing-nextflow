/*
 * -------------------------------------------------
 *  Per-process resource overrides
 * -------------------------------------------------
 */

process {
    // Input validation
    withName: 'VALIDATE_INPUT' {
        cpus   = 1
        memory = 4.GB
        time   = 1.h
    }

    // rMATS processes
    withName: 'ISAR_IMPORT|ISAR_SWITCH_TEST|ISAR_EXTRACT_ORF|ISAR_SWITCH_CONSEQUENCES' {
        maxForks = 1
    }

    withName: 'MAJIQ_PREPARE_ANNOTATION|MAJIQ_BUILD|MAJIQ_DELTAPSI' {
        maxForks = 1
    }

    withName: 'RMATS_PREP' {
        cpus     = 4
        memory   = 16.GB
        time     = 4.h
        maxForks = 2  // limit concurrent Apptainer mounts to avoid squashfuse fork exhaustion
    }
    
    withName: 'RMATS_POST' {
        cpus   = 8
        memory = { 32.GB * task.attempt }
        time   = { 8.h  * task.attempt }
    }

    // MAJIQ processes — requires a user-built image (academic licence, not public).
    // Build: docker build -t your-registry/majiq:3.0 containers/majiq/
    //         OR: apptainer build containers/majiq/majiq.sif containers/majiq/majiq.def
    // Then set params.majiq_sif to the image path/tag.
    withName: 'MAJIQ_BUILD|MAJIQ_DELTAPSI|MAJIQ_ORGANIZE_RESULTS' {
        container = { params.majiq_sif ?: error('MAJIQ container not configured. Build containers/majiq/Dockerfile and pass --majiq_sif <image>. See containers/majiq/Dockerfile for instructions.') }
    }

    withName: 'MAJIQ_BUILD' {
        cpus   = 8
        memory = 32.GB
        time   = 6.h
    }

    withName: 'MAJIQ_DELTAPSI' {
        cpus   = 8
        memory = 16.GB
        time   = 4.h
    }

    withName: 'MAJIQ_ORGANIZE_RESULTS' {
        cpus   = 2
        memory = 8.GB
        time   = 2.h
    }

    // IsoformSwitchAnalyzeR processes — use self-hosted image built from containers/isar/Dockerfile
    withName: 'GFFREAD_TRANSCRIPTOME' {
        cpus   = 2
        memory = 8.GB
        time   = 2.h
    }
    
    withName: 'ISAR_.*' {
        cpus      = 4
        memory    = 32.GB
        time      = 4.h
        container = { params.isar_container ?: 'docker.io/damouzo/alternative-splicing-isar:1.0.0' }
    }

    // Report processes
    withName: 'MULTIQC' {
        cpus   = 2
        memory = 8.GB
        time   = 2.h
    }
    
    withName: 'RENDER_REPORT' {
        cpus      = 2
        memory    = 16.GB
        time      = 2.h
        container = { params.report_container ?: 'docker.io/damouzo/alternative-splicing-report:1.0.0' }
    }
}
