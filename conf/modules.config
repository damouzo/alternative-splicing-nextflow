/*
 * -------------------------------------------------
 *  Per-process resource overrides
 * -------------------------------------------------
 */

process {
    // Input validation
    withName: 'VALIDATE_INPUT' {
        cpus   = 1
        memory = 4.GB
        time   = 1.h
    }

    // rMATS processes
    withName: 'ISAR_IMPORT|ISAR_SWITCH_TEST|ISAR_EXTRACT_ORF|ISAR_SWITCH_CONSEQUENCES' {
        maxForks = 1
    }

    withName: 'MAJIQ_PREPARE_ANNOTATION|MAJIQ_BUILD|MAJIQ_DELTAPSI' {
        maxForks = 1
    }

    withName: 'RMATS_PREP' {
        cpus     = 4
        memory   = 16.GB
        time     = 4.h
        maxForks = 2  // limit concurrent Apptainer mounts to avoid squashfuse fork exhaustion
    }
    
    withName: 'RMATS_POST' {
        cpus   = 8
        memory = 32.GB
        time   = 8.h
    }

    // MAJIQ processes — container resolved from params.majiq_sif (set via MAJIQ_SIF env var or params file)
    withName: 'MAJIQ_BUILD|MAJIQ_DELTAPSI|MAJIQ_VOILA_TSV' {
        container = { params.majiq_sif ?: 'local/majiq:3.0' }
    }

    withName: 'MAJIQ_BUILD' {
        cpus   = 8
        memory = 32.GB
        time   = 6.h
    }

    withName: 'MAJIQ_DELTAPSI' {
        cpus   = 8
        memory = 16.GB
        time   = 4.h
    }

    withName: 'MAJIQ_VOILA_TSV' {
        cpus   = 2
        memory = 8.GB
        time   = 2.h
    }

    // IsoformSwitchAnalyzeR processes
    withName: 'GFFREAD_TRANSCRIPTOME' {
        cpus   = 2
        memory = 8.GB
        time   = 2.h
    }
    
    withName: 'ISAR_.*' {
        cpus   = 4
        memory = 32.GB
        time   = 4.h
    }

    // Report processes
    withName: 'MULTIQC' {
        cpus   = 2
        memory = 8.GB
        time   = 2.h
    }
    
    withName: 'RENDER_REPORT' {
        cpus   = 2
        memory = 16.GB
        time   = 2.h
    }
}
